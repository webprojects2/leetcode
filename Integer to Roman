char* intToRoman(int num) {
    static char result[20];
    int i = 0;

    int values[] = {1000, 900, 500, 400, 100, 90, 50, 40, 10, 9, 5, 4, 1};
    char *symbols[] = {"M", "CM", "D", "CD", "C", "XC", "L", "XL",
                       "X", "IX", "V", "IV", "I"};

    result[0] = '\0';

    for (int j = 0; j < 13; j++) {
        while (num >= values[j]) {
            strcat(result, symbols[j]);
            num -= values[j];
        }
    }

    return result;
}
